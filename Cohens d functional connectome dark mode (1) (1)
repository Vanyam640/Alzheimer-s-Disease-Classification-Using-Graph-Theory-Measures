0;34m(\u001b[0m\u001b[0macronyms\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    341\u001b[0m     \u001b[0mprint\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34mf\"Loaded atlas with {len(acronyms)} ROIs.\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/tmp/ipykernel_3902/3863092569.py\u001b[0m in \u001b[0;36mload_rm96_atlas\u001b[0;34m(path)\u001b[0m\n\u001b[1;32m    135\u001b[0m     \"\"\"\n\u001b[1;32m    136\u001b[0m     \u001b[0;32mif\u001b[0m \u001b[0;32mnot\u001b[0m \u001b[0mos\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mpath\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mexists\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mpath\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 137\u001b[0;31m         \u001b[0;32mraise\u001b[0m \u001b[0mFileNotFoundError\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34mf\"Atlas file not found: {path}\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m    138\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    139\u001b[0m     \u001b[0;32mif\u001b[0m \u001b[0mpath\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mlower\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mendswith\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m\".xlsx\"\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m\".xls\"\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mFileNotFoundError\u001b[0m: Atlas file not found: /content/drive/MyDrive/Vanya_ROI_Plots_Dark/RM96_atlas.xlsx"]}],"source":["\"\"\"Dark-mode, colorblind-friendly ROI brain network plots for Cohen's d group differences.\n","\n","This script:\n","1) Loads node-wise CSV files for clustering, participation, local efficiency, and betweenness.\n","2) Aligns ROI values to the RM96 atlas coordinate order.\n","3) Plots a dark-mode connectome using a pink/light-blue diverging palette.\n","4) Saves separate images for top positive, top negative, and combined top positive/negative ROIs.\n","5) Creates a 2x2 collage figure for the combined panels.\n","\n","Edit the file paths in the CONFIG section if your Drive folders differ.\n","\"\"\"\n","\n","from __future__ import annotations\n","\n","import os\n","import glob\n","from typing import Dict, Tuple, List, Optional\n","\n","import numpy as np\n","import pandas as pd\n","import matplotlib.pyplot as plt\n","from matplotlib import cm\n","from matplotlib.colors import LinearSegmentedColormap, Normalize\n","from PIL import Image\n","\n","# Optional / notebook-friendly import\n","try:\n","    from IPython.display import display\n","except Exception:\n","    display = None\n","\n","try:\n","    import nilearn.plotting as nl_plotting\n","except Exception:\n","    nl_plotting = None\n","\n","\n","# =============================================================================\n","# CONFIG\n","# =============================================================================\n","DRIVE_ROOT = \"/content/drive/MyDrive\"\n","BASE_DIR = os.path.join(DRIVE_ROOT, \"Graph Theory Project\", \"Kira Data\")\n","OUT_DIR = os.path.join(DRIVE_ROOT, \"Vanya_ROI_Plots\")\n","RM96_ATLAS_PATH = os.path.join(OUT_DIR, \"RM96_atlas.xlsx\")\n","\n","NODE_FILES: Dict[str, str] = {\n","    \"clustering\": \"clustering_nodewise_thr03.csv\",\n","    \"participation\": \"participation_nodewise_thr03.csv\",\n","    \"betweenness\": \"betweenness_nodewise_thr03.csv\",\n","    \"local_efficiency\": \"local_efficiency_nodewise_thr03.csv\",\n","}\n","\n","TOPN = 8\n","DISPLAY_MODE = \"lyrz\"\n","BACKGROUND = \"#111111\"\n","FIG_BG = \"#111111\"\n","AX_BG = \"#111111\"\n","TEXT_COLOR = \"#F2F2F2\"\n","SUBTLE_TEXT = \"#BFBFBF\"\n","GRID_COLOR = \"#2A2A2A\"\n","NODE_EDGE = \"#E6E6E6\"\n","HIDDEN_NODE = (0.55, 0.55, 0.55, 0.25)\n","NODE_BASE_SIZE = 28.0\n","NODE_SIZE_BOOST = 210.0\n","\n","# Colorblind-friendly diverging palette on dark background:\n","# negative -> light blue, center -> dark neutral, positive -> pink\n","CB_CMAP = LinearSegmentedColormap.from_list(\n","    \"pink_blue_dark\",\n","    [\"#8ED4FF\", \"#1E1E1E\", \"#FF7AB6\"],\n","    N=256,\n",")\n","\n","# Colorbar for figures that need a stronger neutral center\n","BAR_CMAP = LinearSegmentedColormap.from_list(\n","    \"pink_blue_bar\",\n","    [\"#7FCBFF\", \"#111111\", \"#FF78B4\"],\n","    N=256,\n",")\n","\n","# =============================================================================\n","# Helpers\n","# =============================================================================\n","\n","def install_nilearn_if_needed() -> None:\n","    global nl_plotting\n","    if nl_plotting is None:\n","        import subprocess, sys\n","        subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"--quiet\", \"nilearn\"])\n","        import nilearn.plotting as nl_plotting  # type: ignore\n","\n","\n","def load_csv_robust(path: str) -> pd.DataFrame:\n","    for enc in (\"utf-8\", \"latin1\", \"cp1252\"):\n","        try:\n","            df = pd.read_csv(path, encoding=enc)\n","            df.columns = df.columns.str.strip()\n","            return df\n","        except Exception:\n","            pass\n","    df = pd.read_csv(path, encoding=\"latin1\", engine=\"python\")\n","    df.columns = df.columns.str.strip()\n","    return df\n","\n","\n","def cohens_d(x, y) -> float:\n","    x = np.asarray(x, dtype=float)\n","    y = np.asarray(y, dtype=float)\n","    x = x[np.isfinite(x)]\n","    y = y[np.isfinite(y)]\n","    if len(x) < 2 or len(y) < 2:\n","        return np.nan\n","    pooled = np.sqrt(((len(x) - 1) * np.var(x, ddof=1) + (len(y) - 1) * np.var(y, ddof=1)) / (len(x) + len(y) - 2))\n","    if pooled == 0 or np.isnan(pooled):\n","        return np.nan\n","    return (np.mean(x) - np.mean(y)) / pooled\n","\n","\n","def normalize_roi_name(name: str) -> str:\n","    \"\"\"Normalize ROI acronyms enough to match atlas labels.\"\"\"\n","    s = str(name).strip().upper()\n","    # common suffix variants\n","    for suf in (\"_R\", \"_L\", \"-R\", \"-L\", \".R\", \".L\", \" R\", \" L\"):\n","        if s.endswith(suf):\n","            s = s[: -len(suf)]\n","            break\n","    s = s.replace(\" \", \"\")\n","    return s\n","\n","\n","def load_rm96_atlas(path: str) -> Tuple[np.ndarray, List[str]]:\n","    \"\"\"Load atlas coordinates + acronyms from Excel or CSV.\n","\n","    Expected columns: one acronym-ish column and x/y/z columns.\n","    \"\"\"\n","    if not os.path.exists(path):\n","        raise FileNotFoundError(f\"Atlas file not found: {path}\")\n","\n","    if path.lower().endswith((\".xlsx\", \".xls\")):\n","        atlas = pd.read_excel(path, engine=\"openpyxl\")\n","    else:\n","        atlas = pd.read_csv(path)\n","\n","    atlas.columns = atlas.columns.str.strip()\n","    cols = list(atlas.columns)\n","\n","    acr_col = next((c for c in cols if \"acro\" in c.lower() or c.lower() in {\"roi\", \"name\", \"label\"}), None)\n","    x_col = next((c for c in cols if c.lower() == \"x\"), None)\n","    y_col = next((c for c in cols if c.lower() == \"y\"), None)\n","    z_col = next((c for c in cols if c.lower() == \"z\"), None)\n","\n","    if acr_col is None or x_col is None or y_col is None or z_col is None:\n","        raise ValueError(\n","            f\"Could not infer atlas columns from {path}. Found columns: {cols}. \"\n","            \"Need acronym/name and x, y, z columns.\"\n","        )\n","\n","    acronyms = atlas[acr_col].astype(str).str.strip().tolist()\n","    coords = atlas[[x_col, y_col, z_col]].to_numpy(dtype=float)\n","    return coords, acronyms\n","\n","\n","def build_atlas_lookup(acronyms: List[str]) -> Dict[str, int]:\n","    lookup: Dict[str, int] = {}\n","    for i, a in enumerate(acronyms):\n","        key = normalize_roi_name(a)\n","        if key not in lookup:\n","            lookup[key] = i\n","    return lookup\n","\n","\n","def align_values_to_atlas(metric_df: pd.DataFrame, acronyms: List[str], atlas_lookup: Dict[str, int]) -> Tuple[np.ndarray, int]:\n","    \"\"\"Return values aligned to atlas order.\"\"\"\n","    if \"roi_code\" not in metric_df.columns:\n","        raise ValueError(\"Expected a 'roi_code' column.\")\n","    if \"Cohens_d\" not in metric_df.columns:\n","        # Try to find a likely value column\n","        cand = None\n","        for c in metric_df.columns:\n","            if c.lower() in {\"cohens_d\", \"cohen_d\", \"d\", \"value\"}:\n","                cand = c\n","                break\n","        if cand is None:\n","            num_cols = metric_df.select_dtypes(include=[np.number]).columns.tolist()\n","            if not num_cols:\n","                raise ValueError(\"Could not find a numeric Cohen's d column.\")\n","            cand = num_cols[0]\n","        metric_df = metric_df.rename(columns={cand: \"Cohens_d\"})\n","\n","    vals = np.full(len(acronyms), np.nan, dtype=float)\n","    matched = 0\n","    tmp = metric_df.copy()\n","    tmp[\"norm\"] = tmp[\"roi_code\"].astype(str).apply(normalize_roi_name)\n","\n","    for _, row in tmp.iterrows():\n","        key = row[\"norm\"]\n","        if key in atlas_lookup:\n","            idx = atlas_lookup[key]\n","            try:\n","                vals[idx] = float(row[\"Cohens_d\"])\n","                matched += 1\n","            except Exception:\n","                pass\n","    return vals, matched\n","\n","\n","def get_top_masks(vals: np.ndarray, topn: int = TOPN) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:\n","    finite = np.isfinite(vals)\n","    idx_sorted_pos = np.argsort(vals)[::-1]\n","    idx_sorted_neg = np.argsort(vals)\n","    top_pos = [i for i in idx_sorted_pos if finite[i] and vals[i] > 0][:topn]\n","    top_neg = [i for i in idx_sorted_neg if finite[i] and vals[i] < 0][:topn]\n","    mask_pos = np.zeros(len(vals), dtype=bool)\n","    mask_neg = np.zeros(len(vals), dtype=bool)\n","    mask_pos[top_pos] = True\n","    mask_neg[top_neg] = True\n","    return mask_pos, mask_neg, mask_pos | mask_neg\n","\n","\n","def make_sizes(vals: np.ndarray) -> np.ndarray:\n","    sizes = np.full(len(vals), NODE_BASE_SIZE, dtype=float)\n","    finite = np.isfinite(vals)\n","    if np.any(finite):\n","        absvals = np.abs(vals[finite])\n","        denom = np.nanmax(absvals)\n","        if denom > 0:\n","            sizes[finite] = NODE_BASE_SIZE + NODE_SIZE_BOOST * (np.abs(vals[finite]) / denom)\n","    return sizes\n","\n","\n","def plot_connectome_dark(\n","    vals: np.ndarray,\n","    keep_mask: np.ndarray,\n","    coords: np.ndarray,\n","    title: str,\n","    out_path: str,\n","    vmin: float,\n","    vmax: float,\n","    node_size: Optional[np.ndarray] = None,\n",") -> str:\n","    install_nilearn_if_needed()\n","\n","    n = len(vals)\n","    if node_size is None:\n","        node_size = np.full(n, 55.0)\n","\n","    norm = Normalize(vmin=vmin, vmax=vmax)\n","    node_colors = np.zeros((n, 4), dtype=float)\n","    node_colors[:] = HIDDEN_NODE\n","    if np.any(keep_mask):\n","        node_colors[keep_mask] = CB_CMAP(norm(vals[keep_mask]))\n","        node_colors[keep_mask, 3] = 1.0\n","\n","    disp = nl_plotting.plot_connectome(\n","        adjacency_matrix=np.zeros((n, n)),\n","        node_coords=coords,\n","        node_color=node_colors,\n","        node_size=node_size,\n","        edge_threshold=None,\n","        title=title,\n","        colorbar=False,\n","        display_mode=DISPLAY_MODE,\n","    )\n","\n","    fig = plt.gcf()\n","    fig.patch.set_facecolor(FIG_BG)\n","    for ax in fig.axes:\n","        ax.set_facecolor(AX_BG)\n","        ax.tick_params(colors=TEXT_COLOR)\n","        for spine in ax.spines.values():\n","            spine.set_color(GRID_COLOR)\n","        ax.title.set_color(TEXT_COLOR)\n","        ax.xaxis.label.set_color(TEXT_COLOR)\n","        ax.yaxis.label.set_color(TEXT_COLOR)\n","\n","    fig.subplots_adjust(top=0.90, bottom=0.12, left=0.02, right=0.98)\n","\n","    sm = cm.ScalarMappable(norm=norm, cmap=BAR_CMAP)\n","    sm.set_array([])\n","    cbar_ax = fig.add_axes([0.20, 0.04, 0.60, 0.035])\n","    cbar_ax.set_facecolor(FIG_BG)\n","    cb = fig.colorbar(sm, cax=cbar_ax, orientation=\"horizontal\")\n","    cb.set_label(\"Cohen's d (AD − CN)\", color=TEXT_COLOR)\n","    cb.ax.tick_params(labelsize=9, colors=TEXT_COLOR)\n","    cb.outline.set_edgecolor(TEXT_COLOR)\n","    for t in cb.ax.get_xticklabels():\n","        t.set_color(TEXT_COLOR)\n","\n","    os.makedirs(os.path.dirname(out_path), exist_ok=True)\n","    fig.savefig(out_path, dpi=300, bbox_inches=\"tight\", facecolor=FIG_BG)\n","    plt.close(fig)\n","    try:\n","        disp.close()\n","    except Exception:\n","        pass\n","    return out_path\n","\n","\n","def save_combined_collage(image_paths: List[str], out_path: str, titles: Optional[List[str]] = None) -> str:\n","    \"\"\"Make a 2x2 collage from four saved PNGs.\"\"\"\n","    if len(image_paths) != 4:\n","        raise ValueError(\"Expected exactly 4 images for the collage.\")\n","\n","    imgs = [Image.open(p).convert(\"RGB\") for p in image_paths]\n","    widths = [im.width for im in imgs]\n","    heights = [im.height for im in imgs]\n","    cell_w = max(widths)\n","    cell_h = max(heights)\n","\n","    canvas = Image.new(\"RGB\", (cell_w * 2, cell_h * 2), color=(17, 17, 17))\n","    positions = [(0, 0), (cell_w, 0), (0, cell_h), (cell_w, cell_h)]\n","    for im, pos in zip(imgs, positions):\n","        canvas.paste(im, pos)\n","\n","    os.makedirs(os.path.dirname(out_path), exist_ok=True)\n","    canvas.save(out_path)\n","    return out_path\n","\n","\n","# =============================================================================\n","# Main\n","# =============================================================================\n","\n","def main() -> None:\n","    os.makedirs(OUT_DIR, exist_ok=True)\n","\n","    # Mount Drive only if running in Colab\n","    try:\n","        from google.colab import drive  # type: ignore\n","        print(\"Mounting Google Drive...\")\n","        drive.mount(\"/content/drive\")\n","    except Exception:\n","        print(\"google.colab not available; using local paths as configured.\")\n","\n","    print(\"Base dir:\", BASE_DIR)\n","    print(\"Out dir :\", OUT_DIR)\n","\n","    # Load atlas\n","    coords, acronyms = load_rm96_atlas(RM96_ATLAS_PATH)\n","    atlas_lookup = build_atlas_lookup(acronyms)\n","    print(f\"Loaded atlas with {len(acronyms)} ROIs.\")\n","\n","    # Load metric files\n","    metric_dfs: Dict[str, pd.DataFrame] = {}\n","    for metric, fname in NODE_FILES.items():\n","        path = os.path.join(BASE_DIR, fname)\n","        if not os.path.exists(path):\n","            raise FileNotFoundError(f\"Missing file for {metric}: {path}\")\n","        df = load_csv_robust(path)\n","        if \"diagnosis\" not in df.columns:\n","            # case-insensitive fallback\n","            diag_col = next((c for c in df.columns if c.lower() == \"diagnosis\"), None)\n","            if diag_col is None:\n","                raise ValueError(f\"No diagnosis column found in {path}\")\n","            df = df.rename(columns={diag_col: \"diagnosis\"})\n","        metric_dfs[metric] = df\n","        print(f\"Loaded {metric}: {path} ({len(df)} rows)\")\n","\n","    # Align values and compute global scale\n","    aligned: Dict[str, np.ndarray] = {}\n","    global_max = 1.0\n","    for metric, df in metric_dfs.items():\n","        # pick numeric column if these CSVs are already nodewise metric-only tables\n","        if \"Cohens_d\" not in df.columns:\n","            num_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c]) and c.lower() not in {\"subject_id\", \"threshold_value\"}]\n","            if \"diagnosis\" in num_cols:\n","                num_cols.remove(\"diagnosis\")\n","            if \"subject_id\" in num_cols:\n","                num_cols.remove(\"subject_id\")\n","            if not num_cols:\n","                raise ValueError(f\"Could not infer metric values in {metric} file.\")\n","            # If the file is a subject-level or group table, do not compute Cohen's d here.\n","            # Expecting a precomputed nodewise table with roi_code + Cohens_d.\n","        vals, matched = align_values_to_atlas(df, acronyms, atlas_lookup)\n","        aligned[metric] = vals\n","        finite = vals[np.isfinite(vals)]\n","        if finite.size:\n","            global_max = max(global_max, float(np.max(np.abs(finite))))\n","        print(f\"{metric}: matched {matched}/{len(acronyms)} ROIs\")\n","\n","    # Generate plots\n","    saved = []\n","    summary_rows = []\n","\n","    for metric, vals in aligned.items():\n","        if not np.isfinite(vals).any():\n","            print(f\"Skipping {metric} (no finite values)\")\n","            continue\n","\n","        mask_pos, mask_neg, mask_both = get_top_masks(vals, TOPN)\n","        node_sizes = make_sizes(vals)\n","        vmin, vmax = -global_max, global_max\n","\n","        p_pos = plot_connectome_dark(\n","            vals=vals,\n","            keep_mask=mask_pos,\n","            coords=coords,\n","            title=f\"{metric} — Top {TOPN} positive Cohen's d (AD > CN)\",\n","            out_path=os.path.join(OUT_DIR, f\"topN_pos_{metric}_dark.png\"),\n","            vmin=vmin,\n","            vmax=vmax,\n","            node_size=node_sizes,\n","        )\n","        p_neg = plot_connectome_dark(\n","            vals=vals,\n","            keep_mask=mask_neg,\n","            coords=coords,\n","            title=f\"{metric} — Top {TOPN} negative Cohen's d (AD < CN)\",\n","            out_path=os.path.join(OUT_DIR, f\"topN_neg_{metric}_dark.png\"),\n","            vmin=vmin,\n","            vmax=vmax,\n","            node_size=node_sizes,\n","        )\n","        p_both = plot_connectome_dark(\n","            vals=vals,\n","            keep_mask=mask_both,\n","            coords=coords,\n","            title=f\"{metric} — Top {TOPN} positive/negative Cohen's d\",\n","            out_path=os.path.join(OUT_DIR, f\"topN_both_{metric}_dark.png\"),\n","            vmin=vmin,\n","            vmax=vmax,\n","            node_size=node_sizes,\n","        )\n","\n","        saved.extend([p_pos, p_neg, p_both])\n","        summary_rows.append(\n","            {\n","                \"metric\": metric,\n","                \"top_pos_count\": int(mask_pos.sum()),\n","                \"top_neg_count\": int(mask_neg.sum()),\n","                \"max_abs_d\": float(np.nanmax(np.abs(vals))),\n","                \"mean_d\": float(np.nanmean(vals)),\n","            }\n","        )\n","\n","    # Save summary table\n","    summary_df = pd.DataFrame(summary_rows).sort_values(\"metric\")\n","    summary_csv = os.path.join(OUT_DIR, \"dark_mode_summary.csv\")\n","    summary_df.to_csv(summary_csv, index=False)\n","    print(\"Saved summary:\", summary_csv)\n","    print(summary_df)\n","\n","    # Build collage from the combined panels\n","    collage_paths = [\n","        os.path.join(OUT_DIR, f\"topN_both_{m}_dark.png\")\n","        for m in [\"betweenness\", \"participation\", \"local_efficiency\", \"clustering\"]\n","    ]\n","    if all(os.path.exists(p) for p in collage_paths):\n","        collage_out = os.path.join(OUT_DIR, \"combined_dark_mode_brain_figure.png\")\n","        save_combined_collage(collage_paths, collage_out)\n","        print(\"Saved collage:\", collage_out)\n","    else:\n","        print(\"Skipped collage because one or more combined panels are missing.\")\n","\n","    print(\"\\nAll saved images:\")\n","    for p in saved:\n","        print(\" -\", p)\n","\n","    # Display in notebook if possible\n","    if display is not None:\n","        try:\n","            from IPython.display import Image as IPImage\n","            for p in saved:\n","                display(IPImage(filename=p))\n","        except Exception:\n","            pass\n","\n","\n","if __name__ == \"__main__\":\n","    main()\n"]}]}